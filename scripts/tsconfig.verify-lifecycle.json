{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "outDir": "../.tmp/verify-lifecycle",
    "rootDir": "..",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "noEmitOnError": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": false
  },
  "include": [
    "../scripts/verify-lifecycle.ts",
    "../assets/scripts/core/GameManager.ts",
    "../assets/scripts/core/DataManager.ts",
    "../assets/scripts/core/EventManager.ts",
    "../assets/scripts/gameplay/LevelManager.ts",
    "../assets/scripts/audio/AudioManager.ts",
    "../assets/scripts/platform/PlatformManager.ts",
    "../assets/scripts/platform/PlatformAdapter.ts",
    "../assets/data/constants.ts"
  ]
}
