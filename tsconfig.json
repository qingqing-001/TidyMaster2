{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmitOnError": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./assets/scripts/*"]
    },
    "typeRoots": ["./types", "./node_modules/@types"]
  },
  "include": ["./assets/scripts/**/*"],
  "exclude": ["node_modules", "temp", "build"]
}
